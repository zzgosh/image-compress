# 必填：请求鉴权 Token 列表（逗号分隔，建议每个 Token 都使用 32 bytes 以上随机值）
IMAGE_COMPRESS_API_TOKENS=replace_me_with_a_random_token_1,replace_me_with_a_random_token_2

# 可选：服务监听端口/地址
IMAGE_COMPRESS_API_PORT=3001
IMAGE_COMPRESS_API_HOST=0.0.0.0

# 可选：返回给客户端的公开访问地址（建议生产环境显式设置）
IMAGE_COMPRESS_API_PUBLIC_BASE_URL=http://127.0.0.1:3001

# 可选：上传限制（支持原始字节整数或大写 MB 后缀，例如 25MB）
IMAGE_COMPRESS_API_UPLOAD_MAX_FILE_SIZE=25MB
IMAGE_COMPRESS_API_UPLOAD_MAX_FILE_COUNT=30
IMAGE_COMPRESS_API_UPLOAD_MAX_TOTAL_SIZE=128MB

# 可选：压缩处理并发（按图片维度）
IMAGE_COMPRESS_API_PROCESSING_CONCURRENCY=2

# 可选：请求级并发限制（0 表示关闭；队列上限仅在 MAX_ACTIVE_REQUESTS > 0 时生效）
IMAGE_COMPRESS_API_MAX_ACTIVE_REQUESTS=0
IMAGE_COMPRESS_API_MAX_QUEUED_REQUESTS=0

# 可选：上传暂存目录与总存储上限
# IMAGE_COMPRESS_API_UPLOAD_STAGING_DIR=/tmp/image-compress-api-upload-staging
IMAGE_COMPRESS_API_UPLOAD_STAGING_MAX_SIZE=256MB

# 可选：临时结果保留秒数
IMAGE_COMPRESS_API_RESULT_TTL_SECONDS=120

# 可选：临时结果总存储上限（支持原始字节整数或大写 MB 后缀，例如 512MB）
IMAGE_COMPRESS_API_RESULT_STORAGE_MAX_SIZE=512MB

# 可选：临时结果落盘目录
# IMAGE_COMPRESS_API_RESULT_STORAGE_DIR=/tmp/image-compress-api-results
