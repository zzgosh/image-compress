# 必填：请求鉴权 Token 列表（逗号分隔，建议每个 Token 都使用 32 bytes 以上随机值）
IMAGE_COMPRESS_API_TOKENS=replace_me_with_a_random_token_1,replace_me_with_a_random_token_2

# 可选：服务监听端口/地址
PORT=3001
HOST=0.0.0.0

# 可选：返回给客户端的公开访问地址（建议生产环境显式设置）
PUBLIC_BASE_URL=http://127.0.0.1:3001

# 可选：上传限制（支持原始字节整数或大写 MB 后缀，例如 20MB）
UPLOAD_MAX_FILE_SIZE=20MB
UPLOAD_MAX_FILE_COUNT=30
UPLOAD_MAX_TOTAL_SIZE=80MB

# 可选：临时结果保留秒数
RESULT_TTL_SECONDS=300

# 可选：临时结果总存储上限（支持原始字节整数或大写 MB 后缀，例如 256MB）
RESULT_STORAGE_MAX_SIZE=256MB

# 可选：临时结果落盘目录
# RESULT_STORAGE_DIR=/tmp/image-compress-api-results
