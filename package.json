{
  "name": "image-compress-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Image compression API for VPS deployment",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --env-file=.env ./node_modules/.bin/tsx watch src/server.ts",
