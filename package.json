    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "archiver": "^7.0.1",
    "fastify": "^5.2.1",
    "p-limit": "^6.2.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2"
  }
}
